{
  "expo": {
    "name": "AbsenPIB",
    "slug": "absen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "absen-pib",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.absenpib.app",
      "infoPlist": {
        "NSCameraUsageDescription": "AbsenPIB membutuhkan akses kamera untuk foto selfie absensi.",
        "NSLocationWhenInUseUsageDescription": "AbsenPIB membutuhkan akses lokasi untuk mencatat lokasi absensi Anda."
      }
    },
    "android": {
      "package": "com.absenpib.app",
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c945d227-5904-45c7-a1ad-d35f6e85f449"
      }
    },
    "owner": "wellartdev"
  }
}
